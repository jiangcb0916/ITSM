# 只上传 client/、server/ 和 README.md、.env.example、docs/，其余根目录文件/目录均不提交
/*
!/.gitignore
!/README.md
!/client
!/client/**
!/server
!/server/**
!/docker-compose.yml
!/.env.example
!/docs
!/docs/**
# client、server 内部不提交的内容
node_modules/
dist/
build/
.env
.env.production
.env.local
*.log
.DS_Store
server/data/
client/build/
