# ========== 数据库（与 PostgreSQL 容器一致）==========
DB_NAME=itsm
DB_USER=postgres
DB_PASSWORD=your_secure_password

# ========== JWT ==========
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# ========== 注册邮箱后缀（逗号分隔，不配置则允许所有邮箱）==========
ALLOWED_EMAIL_DOMAINS=company.com,company.cn

# ========== 可选：邮件 SMTP ==========
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=ITSM <noreply@example.com>

# ========== 前端构建时使用的 API 地址（仅构建时生效）==========
# 浏览器访问后端时使用的完整 API 地址。本地部署一般为 http://localhost:3011/api
# 服务器部署改为实际域名或 IP，例如：http://your-server:3011/api
REACT_APP_API_URL=http://localhost:3011/api

# ========== 其他 ==========
NODE_ENV=production
