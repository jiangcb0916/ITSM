PORT=3011
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=itsm
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ITSM <noreply@example.com>

# 注册邮箱后缀限制（逗号分隔，不配置则允许所有邮箱）
# ALLOWED_EMAIL_DOMAINS=company.com,company.cn

# Upload
UPLOAD_DIR=./data/uploads
