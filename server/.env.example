# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ITSM <noreply@example.com>

# Upload
UPLOAD_DIR=./data/uploads
